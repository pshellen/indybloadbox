BEFORE_FIRST_SHOW = 60
BEFORE_OTHER_SHOWS = 30
UPCOMING_MINUTES = 25

COLOR_NOW = (0.45, 0.78, 1.0, 1.0)      # light blue border / badge
COLOR_UPCOMING = (0.02, 0.55, 0.18, 1.0) # green

IMGIX_BASE = "https://indy-systems.imgix.net/" 
UA = 'Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/147.0.0.0 Safari/537.36'

def localize(dt):
    unix = calendar.timegm(dt.timetuple())
    dt = dt.replace(tzinfo=pytz.utc)
    dt = dt.astimezone(DEVICE_TZ)
    dt = dt.replace(tzinfo=None)
    return dt, unix

def pairwise(iterable):
    a, b = tee(iterable)
    b = chain(islice(b, 1, None), [None])
    return zip(a, b)

def send_clock():
    node.send('/time/set:%s' % (
        localize(datetime.utcnow())[0].strftime("%H:%M"),
    ))

def fetch_into(src, dst):
    if os.path.exists(dst):
        return dst
    try:
        r = requests.get(
            src,
            headers = {
                'User-Agent': UA,
            },
            timeout = 10,
        )
        r.raise_for_status()
        with tempfile.NamedTemporaryFile(dir=os.getcwd()) as tmp:
            tmp.write(r.content)
            tmp.flush()
            os.rename(tmp.name, dst)
            tmp.delete = False
        return dst
    except Exception as err:
        traceback.print_exc()
        time.sleep(30) # enforce minimum error delay
        return None

def fetch_indy(screen_id):
    try:
        r = requests.post(
            "https://api-us.indy.systems/graphql", 
            headers = {
                'User-Agent': UA,
                'Accept': 'application/graphql-response+json',
                'Content-Type': 'application/json',
            },
            timeout = 5,
            data = '''
                {"query": "{ screen(id: \\"%d\\") {name todaysShowings { time current past showingBadges { id title displayName } movie { name posterImage animatedPosterVideo showingStatus duration rating ratingReason }}}}"}
            '''.strip() % (screen_id,)
        )
        r.raise_for_status()
        return r.json()['data']['screen']
    except Exception as err:
        traceback.print_exc()
        time.sleep(30) # enforce minimum error delay
        return None

def parse_indy(screen):
    now = time.time()

    def iter_shows():
        for show in screen['todaysShowings']:
            start, unix = localize(datetime.strptime(show['time'], "%Y-%m-%dT%H:%M:%SZ"))
            poster = show['movie']['posterImage']
            animated = show['movie'].get('animatedPosterVideo')
            poster_file = ""
            media_type = "image"

            if animated:
                poster_file = fetch_into(
                    src = '%s/%s?auto=format,compress' % (IMGIX_BASE, animated),
                    dst = 'motion-%s.mp4' % animated,
                )
                if poster_file:
                    media_type = "video"

            if not poster_file and poster:
                poster_file = fetch_into(
                    src = '%s/%s?fit=crop&w=1000&h=1500&fm=jpeg&auto=format,compress&cs=origin' % (IMGIX_BASE, poster),
                    dst = 'poster-%s.jpg' % poster,
                )

            status = show['movie'].get('showingStatus') or ''

            is_3d = False
            for badge in (show.get('showingBadges') or []):
                title = (badge.get('title') or badge.get('displayName') or '').strip().lower()
                if title == '3d' or title.startswith('3d ') or ' 3d' in title:
                    is_3d = True
                    break

            yield dict(
                unix = unix,
                start = start.strftime("%-I:%M %p").upper(),
                past = show['past'],
                current = show['current'],
                name = show['movie']['name'],
                rating = show['movie'].get('rating') or '',
                rating_reason = show['movie'].get('ratingReason') or '',
                runtime = show['movie']['duration'],
                status = status,
                status_label = status.upper(),
                is_3d = is_3d,
                upcoming = False,
                color = COLOR_NOW,
                poster_file = poster_file or "",
                media_type = media_type,
            )

    shows = list(iter_shows())
    out = {
        'name': screen['name'],
    }

    def show_end(idx):
        show = shows[idx]
        if idx + 1 < len(shows):
            return shows[idx + 1]['unix']
        runtime = show.get('runtime') or 120
        return show['unix'] + runtime * 60

    # 1) Upcoming window: 25 minutes before start until start
    for idx, show in enumerate(shows):
        upcoming_from = show['unix'] - UPCOMING_MINUTES * 60
        if upcoming_from <= now < show['unix']:
            show = dict(show)
            show['upcoming'] = True
            show['status_label'] = 'NEXT SHOWING'
            show['color'] = COLOR_UPCOMING
            out['show'] = show
            return out

    # 2) Playing window: start until next show (or start + runtime)
    for idx, show in enumerate(shows):
        if show['unix'] <= now < show_end(idx):
            show = dict(show)
            show['upcoming'] = False
            show['status_label'] = 'NOW PLAYING'
            show['color'] = COLOR_NOW
            out['show'] = show
            return out

    # 3) Fall back to Indy's current flag
    for show in shows:
        if show['current']:
            show = dict(show)
            show['upcoming'] = False
            show['status_label'] = 'NOW PLAYING'
            show['color'] = COLOR_NOW
            out['show'] = show
            break

    return out

def resolve_sign(signs, serial):
    for sign in signs:
        if sign['serial'] == serial:
            return sign
    if len(signs) == 1:
        print >>sys.stderr, "WARNING: device serial %s not in config; using the only configured sign" % serial
        return signs[0]
    return None

def update_thread():
    my_serial = os.environ['SERIAL']
    sign = resolve_sign(config.signs, my_serial)
    if sign is None:
        print >>sys.stderr, "couldn't find my sign"
        return

    should_blank = sign['blank']
    device.turn_screen_on()

    while 1:
        indy_data = fetch_indy(sign['indy_id'])
        if indy_data is None:
            print >>sys.stderr, "No screen data"
            time.sleep(60)
            continue

        with open('indy.json', 'wb') as f:
            json.dump(indy_data, f)

        for wait in xrange(12):
            screen_data = parse_indy(indy_data)
            with open('screen.json', 'wb') as f:
                json.dump(screen_data, f)

            if should_blank: 
                if 'show' in screen_data:
                    device.turn_screen_on()
                else:
                    device.turn_screen_off()

            time.sleep(10)

def test():
    from pprint import pprint
    with open('indy.json', 'rb') as f:
        screen = json.load(f)
        pprint(parse_indy(screen))

def main():
    if 'TEST' in os.environ:
        send_clock()
        test()
        return

    while time.time() < 1000000:
        print >>sys.stderr, "waiting for correct time"
        time.sleep(1)

    if 'SERIAL' in os.environ:
        update = threading.Thread(target=update_thread)
        update.daemon = True
        update.start()
    else:
        print >>sys.stderr, "updating disabled"

    while 1:
        send_clock()
        time.sleep(5)

if __name__ == "__main__":
    main()
